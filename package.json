{
  "name": "ryvonx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-dev-cache.mjs && node --use-system-ca node_modules/next/dist/bin/next dev --turbopack",
    "dev:clean": "powershell -ExecutionPolicy Bypass -Command \"Get-NetTCPConnection -LocalPort 3000,3001 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; if (Test-Path .next) { Remove-Item -Recurse -Force .next }; npm run dev\"",
    "build": "npm run check:types && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "npm run check:types && tsc --noEmit",
    "check:types": "node scripts/check-database-types.mjs",
    "verify": "npm run check:types && npm run build",
    "db:link": "supabase link",
    "db:push": "supabase db push --yes",
    "db:types": "powershell -ExecutionPolicy Bypass -File ./scripts/safe-gen-types.ps1",
    "db:types:local": "supabase gen types typescript --local > src/types/database.types.ts",
    "db:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/db-migrate.ps1",
    "db:status": "powershell -ExecutionPolicy Bypass -File ./scripts/db-status.ps1",
    "supabase:login": "supabase login"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-query-devtools": "^5.80.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.18.1",
    "lucide-react": "^0.514.0",
    "next": "^15.3.3",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "recharts": "^2.15.3",
    "sonner": "^2.0.5",
    "standardwebhooks": "^1.0.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.63"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3"
  }
}
