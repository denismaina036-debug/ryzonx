# =============================================================================
# Ryvonx Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Ryvonx
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Supabase (Public — safe for client-side)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# Supabase CLI (for automatic migrations — server-only, never commit)
# Get project ref from Dashboard URL: supabase.com/dashboard/project/<ref>
# Get DB password from: Project Settings > Database > Database password
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-database-password

# -----------------------------------------------------------------------------
# Supabase (Server-only — NEVER expose to client)
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Feature Flags (optional — for gradual rollouts)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_REGISTRATION=true
NEXT_PUBLIC_ENABLE_DEPOSITS=true
NEXT_PUBLIC_ENABLE_WITHDRAWALS=true

# -----------------------------------------------------------------------------
# Analytics (future)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=

# -----------------------------------------------------------------------------
# Email (future)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
# EMAIL_FROM=notifications@ryvonx.com
